generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Paper {
  id          String   @id @default(uuid())
  title       String
  authors     String[]
  abstract    String
  keywords    String[] @default([])
  field       String
  pdfUrl      String   @map("pdf_url")
  pdfKey      String   @map("pdf_key")
  doi         String?  @unique
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  reviews     Review[]

  @@index([field])
  @@index([keywords])
  @@index([createdAt])
  @@index([title])
  @@map("papers")
}

enum ReviewerType {
  AI
  HUMAN

  @@map("reviewer_type")
}

model Review {
  id              String       @id @default(uuid())
  paperId         String       @map("paper_id")
  reviewerType    ReviewerType @map("reviewer_type")
  reviewerId      String?      @map("reviewer_id")
  content         Json
  isAccepted      Boolean?     @map("is_accepted")
  confidenceScore Float?       @map("confidence_score")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  paper           Paper        @relation(fields: [paperId], references: [id], onDelete: Cascade)
  reviewer        User?        @relation(fields: [reviewerId], references: [id])

  @@index([paperId])
  @@index([reviewerType])
  @@map("reviews")
}

model AgentConfig {
  id             String   @id @default(uuid())
  name           String   @unique
  skillsMarkdown String   @map("skills_markdown")
  tone           String   @default("Academic")
  systemPrompt   String   @map("system_prompt")
  version        Int      @default(1)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("agent_configs")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("reviewer")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  reviews   Review[]

  @@map("users")
}
