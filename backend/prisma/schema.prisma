generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum ConferenceTier {
  ENTRY
  STANDARD
  PREMIUM
  ELITE

  @@map("conference_tier")
}

enum ConferenceStatus {
  UPCOMING
  ACTIVE
  ARCHIVED

  @@map("conference_status")
}

enum ReviewAttitude {
  POSITIVE
  NEUTRAL
  NEGATIVE

  @@map("review_attitude")
}

enum ReviewerType {
  AI
  HUMAN

  @@map("reviewer_type")
}

enum AgentType {
  REVIEWER
  ANALYST
  CURATOR

  @@map("agent_type")
}

enum AgentTier {
  ENTRY
  STANDARD
  PREMIUM
  ELITE

  @@map("agent_tier")
}

enum SkillLevel {
  NOVICE
  PROFICIENT
  EXPERT

  @@map("skill_level")
}

// ==================== MODELS ====================

model Paper {
  id          String   @id @default(uuid())
  title       String
  authors     String[]
  abstract    String
  keywords    String[] @default([])
  field       String
  pdfUrl      String   @map("pdf_url")
  pdfKey      String   @map("pdf_key")
  doi         String?  @unique
  
  // Owner
  userId      String   @map("user_id")
  
  // Final result from synthesis
  finalResult String?  @map("final_result") // ACCEPT, REJECT, MAJOR_REVISION
  
  // Skills required to review this paper
  requiredSkills String[] @default([]) @map("required_skills")
  skillConfidence Float?   @map("skill_confidence")
  
  // Conference link
  conferenceId    String?  @map("conference_id")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  reviews     Review[]
  synthesis   ReviewSynthesis?
  reviewers   String[] @default([]) // Array of agent IDs assigned to review
  conference  Conference? @relation(fields: [conferenceId], references: [id])
  user        User @relation(fields: [userId], references: [id])

  @@index([field])
  @@index([keywords])
  @@index([createdAt])
  @@index([title])
  @@index([userId])
  @@map("papers")
}

model Review {
  id        String   @id @default(uuid())
  paperId   String   @map("paper_id")
  agentId   String   @map("agent_id") // ID of the agent that gave this review
  
  // Review content
  text      String   // Freeform review text
  attitude  ReviewAttitude @default(NEUTRAL) // POSITIVE, NEUTRAL, NEGATIVE
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([agentId])
  @@map("reviews")
}

// TinyFish Synthesis: Singularity decision from council reviews
model ReviewSynthesis {
  id          String   @id @default(uuid())
  paperId     String   @unique @map("paper_id")
  
  // The synthesized summary
  summary     String   // Brief paragraph summarizing all reviews
  strengths   String[] // Key strengths identified
  weaknesses  String[] // Key weaknesses identified
  recommendation String // "ACCEPT", "REJECT", or "MAJOR_REVISION"
  confidence  Float    // 0-1 confidence in the recommendation
  
  // Source tracking
  reviewCount Int      @map("review_count") // How many reviews were synthesized
  councilIds  String[] @map("council_ids") // Which agents contributed
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  paper       Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@map("review_syntheses")
}

model AgentSkill {
  id          String    @id @default(uuid())
  agentId     String    @map("agent_id")
  name        String
  level       SkillLevel @default(NOVICE)
  verified    Boolean   @default(false)
  reviewCount Int       @default(0) @map("review_count")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  agent       AgentConfig @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, name])
  @@index([agentId])
  @@index([name])
  @@map("agent_skills")
}

model AgentReputation {
  id                String   @id @default(uuid())
  agentId           String   @unique @map("agent_id")
  
  // Tier
  tier              AgentTier @default(ENTRY)
  
  // Core metrics
  reviewCount       Int      @default(0) @map("review_count")
  accuracyScore     Float    @default(0) @map("accuracy_score")
  helpfulnessScore  Float    @default(0) @map("helpfulness_score")
  consistencyScore  Float    @default(0) @map("consistency_score")
  
  // Calculated reputation (0-100)
  overallReputation Float    @default(0) @map("overall_reputation")
  
  // Rate limiting
  reviewsThisWeek   Int      @default(0) @map("reviews_this_week")
  lastReviewAt      DateTime? @map("last_review_at")
  
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  // Relations
  agent             AgentConfig @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@index([overallReputation])
  @@map("agent_reputations")
}

model AgentConfig {
  id             String   @id @default(uuid())
  name           String   @unique
  agentType      AgentType @default(REVIEWER) @map("agent_type")
  
  // Skill file references
  skillsUrl      String   @default("/SKILL.md") @map("skills_url")
  reviewUrl      String   @default("/REVIEW.md") @map("review_url")
  fieldsUrl      String   @default("/FIELDS.md") @map("fields_url")
  ethicsUrl      String   @default("/ETHICS.md") @map("ethics_url")
  
  // Configuration
  tone           String   @default("Academic")
  systemPrompt   String   @map("system_prompt")
  fields         String[] @default([])
  
  // Versioning
  version        Int      @default(1)
  isActive       Boolean  @default(true) @map("is_active")
  
  // Metadata
  description    String?
  createdBy      String?  @map("created_by")
  apiKey         String?  @unique @map("api_key")
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  // Relations
  skills         AgentSkill[]
  reputation     AgentReputation?

  @@index([isActive])
  @@index([agentType])
  @@map("agent_configs")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String   @default("")
  role        String   @default("reviewer")
  avatarUrl   String?  @map("avatar_url")
  affiliation String?  @default("")
  bio         String?  @default("")
  location    String?  @default("")
  
  // Auth
  passwordHash String? @map("password_hash")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  papers      Paper[]

  @@map("users")
}

model Conference {
  id          String    @id @default(uuid())
  name        String
  acronym     String?
  tier        ConferenceTier @default(STANDARD)
  status      ConferenceStatus @default(UPCOMING)
  
  // Skill requirements
  requiredSkills String[] @default([]) @map("required_skills")
  
  // Metadata
  publisher   String?
  website     String?
  description String?
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  papers      Paper[]

  @@index([tier])
  @@index([status])
  @@map("conferences")
}
